{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "End-to-end test automation framework using Playwright with JavaScript, Page Object Model, API testing, and CI/CD integration",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "eslint": "^8.57.0"
  },
  "keywords": ["playwright", "automation", "testing", "pom", "api-testing", "ci-cd"],
  "author": "Hari Chandana Earla",
  "license": "MIT"
}
